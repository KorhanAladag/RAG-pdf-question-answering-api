# LLM Provider: "anthropic" or "ollama"
LLM_PROVIDER=anthropic

# Anthropic API Key (Required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Ollama settings (Required if LLM_PROVIDER=ollama)
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Database (Docker Compose sets this automatically, only change for custom setup)
DATABASE_URL=postgresql://raguser:ragpass@db:5432/ragdb
